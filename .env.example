# ============================================
# RABAT Portal — variables de entorno
# Copia este archivo a .env.local y rellena los valores.
# .env.local está en .gitignore — NUNCA lo subas al repo.
# ============================================

# ── Google Drive + Sheets ────────────────────────────────────────────────────
# Paso 1: Google Cloud Console → IAM → Cuentas de servicio → Crear → Añadir clave (JSON)
# Paso 2: Del JSON descargado, copiar "client_email" y "private_key"
# Paso 3: Compartir la carpeta "RABAT" en Drive con GOOGLE_CLIENT_EMAIL (permiso Editor)
# Paso 4: Compartir el Sheet "RABAT_releases" con GOOGLE_CLIENT_EMAIL (permiso Editor)
#
# IMPORTANTE para GOOGLE_PRIVATE_KEY:
#   En el JSON tiene saltos de línea reales. En .env.local guardar así:
#   GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
#   (los \n son literales — el código los convierte automáticamente)
GOOGLE_CLIENT_EMAIL=tu-service-account@proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ID de la carpeta raíz "RABAT" en Google Drive
# (de la URL: drive.google.com/drive/folders/{ESTE_ES_EL_ID})
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ID del Google Sheet "RABAT_releases"
# (de la URL: docs.google.com/spreadsheets/d/{ESTE_ES_EL_ID}/edit)
# El Sheet debe tener 5 pestañas con sus headers en la primera fila:
#   releases | tracks | credits | royalty_splits | artists
GOOGLE_SHEET_ID=

# ── NextAuth / magic link (pendiente de activar) ─────────────────────────────
# Proveedor SMTP recomendado: Resend (resend.com) — gratis hasta 3000 emails/mes
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@rabat.com

NEXTAUTH_URL=http://localhost:3000
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=

# ── Aviso por email a RABAT cuando un artista envía un tema ───────────────────
# Usa Resend (resend.com). Crea una API key en Resend → API Keys.
# Para enviar a cualquier dirección hay que verificar el dominio en Resend y usar
# un NOTIFY_FROM de ese dominio (p.ej. portal@rabatmusicgroup.com). Sin dominio
# verificado, con onboarding@resend.dev solo puedes enviar al email de tu cuenta Resend.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
NOTIFY_EMAIL=ar@rabatmusicgroup.com
NOTIFY_FROM=RABAT <portal@rabatmusicgroup.com>
